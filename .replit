modules = ["nodejs-20", "web", "python-3.12"]
[agent]
expertMode = true
stack = "FLASK_VANILLA_JS"

[nix]
channel = "stable-25_05"
packages = ["freetype", "glibcLocales", "openssl", "postgresql", "tesseract", "xcodebuild", "zlib"]

[workflows]

[[workflows.workflow]]
name = "Flask Server"
author = 47704679
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python app.py"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:5000", "main:app"]

[userenv]

[userenv.shared]
ADMIN_USERNAME = "admin"
FLASK_ENV = "development"
